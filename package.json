{
  "name": "mobile-drone-app",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:galaxy": "expo start --lan --clear",
    "start:galaxy:tunnel": "expo start --tunnel --clear",
    "galaxy:preflight": "node scripts/galaxy-preflight.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "web:export": "expo export --platform web --output-dir dist-check",
    "check": "npm run typecheck && npm run doctor"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.2",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.1.6",
    "@supabase/supabase-js": "^2.49.8",
    "base64-arraybuffer": "^1.0.2",
    "expo": "^53.0.11",
    "expo-asset": "~11.1.7",
    "expo-constants": "~17.1.8",
    "expo-file-system": "^18.1.11",
    "expo-font": "~13.3.2",
    "expo-image-picker": "^16.1.4",
    "expo-linking": "^7.1.7",
    "expo-location": "^18.1.6",
    "expo-router": "^5.0.7",
    "expo-status-bar": "^2.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.20.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3"
  }
}
